<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:UI.Helpers"
        xmlns:vm="clr-namespace:UI.ViewModels"
        xmlns:views="clr-namespace:UI.Views"
        xmlns:local="clr-namespace:UI"  
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="RistorantiLab"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d" Height="640" Width="960">

    <Window.Resources>
        <helpers:SezioneToNavStyleConverter x:Key="SezionToNavStyleConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- DataTemplate: mappa ogni ViewModel alla sua View -->

        <!--<DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>-->

        <DataTemplate DataType="{x:Type vm:RistoranteListViewModel}">
            <views:RistoranteListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RistoranteDetailViewModel}">
            <views:RistoranteDetailView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:UtenteListViewModel}">
            <views:UtenteListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:UtenteDetailViewModel}">
            <views:UtenteDetailView/>
        </DataTemplate>


        <DataTemplate DataType="{x:Type vm:PrenotazioneListViewModel}">
            <views:PrenotazioneListView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PrenotazioneDetailViewModel}">
            <views:PrenotazioneDetailView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:StatisticheViewModel}">
            <views:StatisticheView/>
        </DataTemplate>

        <!-- Stile voce menu normale -->
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="#CECBF6"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Height"       Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"      Value="16,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="6,1">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3C3489"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#534AB7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stile voce menu attiva -->
        <Style x:Key="NavItemActiveStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavItemStyle}">
            <Setter Property="Background"  Value="#3C3489"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="Medium"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar — visibile solo dopo il login -->
            <ColumnDefinition Width="200">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsMenuVisibile}"
                                Value="False">
                                <Setter Property="Width" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            <!-- Area contenuto -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--Sidebar -->
        <Grid Grid.Column="0"
              Width="200"
              Background="#26215C"
              Visibility="{Binding IsMenuVisibile,
                   Converter={StaticResource BooleanToVisibilityConverter}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Logo -->
                <RowDefinition Height="*"/>
                <!-- Voci menu -->
                <RowDefinition Height="Auto"/>
                <!-- Footer utente -->
            </Grid.RowDefinitions>

            <!-- Logo -->
            <Border Grid.Row="0"
                    BorderBrush="#3C3489"
                    BorderThickness="0,0,0,1"
                    Padding="16,20">
                <TextBlock Text="RistorantiLab"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>

            <!-- Voci di navigazione -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0">

                <Button Content="Ristoranti"
                        Command="{Binding VaiARistorantiCommand}"
                        Style="{Binding SezioneAttiva,
                                Converter={StaticResource SezionToNavStyleConverter},
                                ConverterParameter=Ristoranti}"/>

                <Button Content="Prenotazioni"
                        Command="{Binding VaiAPrenotazioniCommand}"
                        Style="{Binding SezioneAttiva,
                                Converter={StaticResource SezionToNavStyleConverter},
                                ConverterParameter=Prenotazioni}"/>

                <Button Content="Utenti"
                        Command="{Binding VaiAUtentiCommand}"
                        Style="{Binding SezioneAttiva,
                                Converter={StaticResource SezionToNavStyleConverter},
                                ConverterParameter=Utenti}"/>

                <Button Content="Statistiche"
                        Command="{Binding VaiAStatisticheCommand}"
                        Style="{Binding SezioneAttiva,
                                Converter={StaticResource SezionToNavStyleConverter},
                                ConverterParameter=Statistiche}"/>

            </StackPanel>

            <!-- Footer: utente loggato + logout -->
            <Border Grid.Row="2"
                    BorderBrush="#3C3489"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding UtenteCorrente.Username}"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="White"/>
                        <TextBlock FontSize="11" Foreground="#7F77DD">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Utente"/>
                                    <Style.Triggers>
                                        <DataTrigger
                                            Binding="{Binding IsAmministrator}"
                                            Value="True">
                                            <Setter Property="Text"
                                                    Value="Amministratore"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Bottone logout -->
                    <Button Grid.Column="1"
                            Command="{Binding LogoutCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Logout"
                            Padding="6">
                        <Path Data="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4
                                    M16 17l5-5-5-5 M21 12H9"
                              Stroke="#CECBF6" StrokeThickness="1.5"
                              StrokeLineJoin="Round" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="18" Height="18"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!--Contenuto -->
        <Border Grid.Column="1"
                Background="White"
                Margin="0">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>

    </Grid>
</Window>
