<UserControl x:Class="UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             xmlns:helpers="clr-namespace:UI.Helpers"
             >

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="340"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="32">

            <StackPanel>

                <!-- Logo / titolo -->
                <TextBlock Text="RistorantiLab"
                           FontSize="22" FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Accedi al gestionale"
                           FontSize="13" Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Username -->
                <TextBlock Text="Username"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username,
                                UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             Margin="0,0,0,20"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Pannello errore -->
                <Border Background="#FFEBE8" BorderBrush="#E24B4A"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,7" Margin="0,0,0,16"
                        Visibility="{Binding MessaggioErrore,
                                     Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{Binding MessaggioErrore}"
                               Foreground="#A32D2D" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Bottone login -->
                <Button Content="Accedi"
                        Command="{Binding LoginCommand}"
                        Height="36"
                        Background="#534AB7" Foreground="White"
                        BorderThickness="0"
                        FontSize="14"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
