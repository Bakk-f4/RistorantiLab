<UserControl x:Class="UI.Views.RistoranteListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:UI.Helpers"
             xmlns:local="clr-namespace:UI.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>


    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header con bottoni -->
            <RowDefinition Height="Auto"/>
            <!-- barra ricerca     -->
            <RowDefinition Height="Auto"/>
            <!-- messaggio errore -->
            <RowDefinition Height="Auto"/>
            <!-- messaggio successo -->
            <RowDefinition Height="*"/>
            <!-- tabella -->
        </Grid.RowDefinitions>

        <!-- Titolo -->
        <!-- Header: titolo + bottoni -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Ristoranti"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">

                <Button Content="Nuovo"
                        Command="{Binding NuovoCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Background="#534AB7" Foreground="White"
                        BorderThickness="0"
                        Visibility="{Binding IsAdministrator, 
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Content="Modifica"
                        Command="{Binding ModificaCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding IsAdministrator, 
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Content="Elimina"
                        Command="{Binding EliminaCommand}"
                        Padding="12,6"
                        Visibility="{Binding IsAdministrator,
                    Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>


        <Border Grid.Row="1"
                Background="#F8F8F8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Filtro città -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Città"
                       FontSize="11" Foreground="#666"
                       Margin="0,0,0,3"/>
                    <TextBox Height="25" Text="{Binding FiltroCitta,
                            UpdateSourceTrigger=PropertyChanged}"
                     Tag="Es. Milano"/>
                </StackPanel>

                <!-- Filtro tipologia -->
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Tipologia"
                       FontSize="11" Foreground="#666"
                       Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding TipologieDisponibili}"
                      SelectedItem="{Binding TipologiaSelezionata}"/>
                </StackPanel>

                <!-- Filtro prezzo massimo -->
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Prezzo max (€)"
                       FontSize="11" Foreground="#666"
                       Margin="0,0,0,3"/>
                    <TextBox Height="25" Text="{Binding FiltroPrezzoMax,
                            UpdateSourceTrigger=PropertyChanged,
                            TargetNullValue=''}"/>
                </StackPanel>

                <!-- Bottone Cerca -->
                <Button Grid.Column="3"
                Content="Cerca"
                Command="{Binding CercaCommand}"
                Padding="14,6"
                Margin="0,0,6,0"
                VerticalAlignment="Bottom"
                Background="#534AB7" Foreground="White"
                BorderThickness="0"/>

                <!-- Bottone Reset -->
                <Button Grid.Column="4"
                Content="Reset"
                Command="{Binding ResetCommand}"
                Padding="14,6"
                VerticalAlignment="Bottom"/>

            </Grid>
        </Border>


        <!-- Pannello errore -->
        <Border Grid.Row="2"
                Background="#FFEBE8" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding MessaggioErrore, 
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioErrore}"
                       Foreground="#A32D2D" FontSize="13"/>
        </Border>

        <!-- Pannello successo -->
        <Border Grid.Row="3"
                Background="#E8F5E9" BorderBrush="#4CAF50"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding MessaggioSuccesso, 
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioSuccesso}"
                       Foreground="#2E7D32" FontSize="13"/>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding ListaRistoranti}"
                  SelectedItem="{Binding RistoranteSelezionato}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserSortColumns="True"
                  AlternatingRowBackground="#F8F8F8"
                  BorderThickness="1" BorderBrush="#E0E0E0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Ragione sociale"
                                    Binding="{Binding RagioneSociale}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Città"
                                    Binding="{Binding Citta}"
                                    Width="*"/>
                <DataGridTextColumn Header="Tipologia"
                                    Binding="{Binding Tipologia}"
                                    Width="*"/>
                <DataGridTextColumn Header="Posti"
                                    Binding="{Binding NumPosti}"
                                    Width="60"/>
                <DataGridTextColumn Header="Prezzo medio"
                                    Binding="{Binding PrezzoMedio, 
                                              StringFormat='€ {0:N2}'}"
                                    Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
