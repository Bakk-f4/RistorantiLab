<UserControl x:Class="UI.Views.PrenotazioneDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>



    <Grid Margin="16" MaxWidth="560">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- titolo -->
            <RowDefinition Height="Auto"/>
            <!-- form -->
            <RowDefinition Height="Auto"/>
            <!-- card posti -->
            <RowDefinition Height="Auto"/>
            <!-- errore -->
            <RowDefinition Height="Auto"/>
            <!-- bottoni -->
        </Grid.RowDefinitions>

        <!-- Titolo -->
        <TextBlock Grid.Row="0"
                   Text="{Binding Titolo}"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Form -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Utente -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,14">
                <TextBlock Text="Cliente *"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>

                <ComboBox ItemsSource="{Binding ListaUtentiFiltrata}"
                          SelectedItem="{Binding UtenteSelezionato}"
                          DisplayMemberPath="Username"
                          IsEnabled="{Binding IsAdministrator}"/>
                
            </StackPanel>

            <!-- Data e ora -->
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Data prenotazione *"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DataPrenotazione}"/>
            </StackPanel>

            <!-- Numero persone -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Numero persone *"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <TextBox Text="{Binding NumPersone,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

        </Grid>

        <!-- Card posti disponibili — si aggiorna in tempo reale -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="#F5F5F5" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Posti totali"
                               FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding RistoranteCorrente.NumPosti}"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#1A1A1A"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="8,0,0,0"
                    CornerRadius="8" Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#F0FFF4"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PostiDisponibili}"
                                         Value="0">
                                <Setter Property="Background" Value="#FFF3F3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Disponibili per la data scelta"
                               FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding PostiDisponibili}"
                               FontSize="24" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2E7D32"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PostiDisponibili}"
                                                 Value="0">
                                        <Setter Property="Foreground"
                                                Value="#A32D2D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Pannello errore -->
        <Border Grid.Row="3"
                Background="#FFEBE8" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16"
                Visibility="{Binding MessaggioErrore,
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioErrore}"
                       Foreground="#A32D2D" FontSize="13"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Bottoni -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Annulla"
                    Command="{Binding AnnullaCommand}"
                    Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="Conferma prenotazione"
                    Command="{Binding SalvaCommand}"
                    Padding="16,8"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

    </Grid>

</UserControl>
