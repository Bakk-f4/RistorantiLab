<UserControl x:Class="UI.Views.StatisticheView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:local="clr-namespace:UI.Views"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- header -->
                <RowDefinition Height="Auto"/>
                <!-- filtri -->
                <RowDefinition Height="Auto"/>
                <!-- KPI cards -->
                <RowDefinition Height="Auto"/>
                <!-- errore -->
                <RowDefinition Height="300"/>
                <!-- grafico -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                       Text="Statistiche"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                    Content="Aggiorna"
                    Command="{Binding AggiornCommand}"
                    Padding="16,6"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0"/>
            </Grid>

            <!-- Filtri -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Ristorante"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ListaRistoranti}"
                          SelectedItem="{Binding RistoranteSelezionato}"
                          DisplayMemberPath="RagioneSociale"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Data inizio"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding DataInizio}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Data fine"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding DataFine}"/>
                </StackPanel>
            </Grid>

            <!-- KPI cards -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Totale prenotazioni -->
                <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="#F5F5F5" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Totale prenotazioni"
                               FontSize="12" Foreground="#666"
                               Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalePrenotazioni}"
                               FontSize="28" FontWeight="SemiBold"
                               Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>

                <!-- Totale persone -->
                <Border Grid.Column="1" Margin="4,0"
                    Background="#F5F5F5" CornerRadius="8" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="Persone totali"
                               FontSize="12" Foreground="#666"
                               Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding TotalePersone}"
                               FontSize="28" FontWeight="SemiBold"
                               Foreground="#1A1A1A"/>
                    </StackPanel>
                </Border>

                <!-- Tasso occupazione — solo se ristorante specifico -->
                <Border Grid.Column="2" Margin="8,0,0,0"
                    Background="#EEEDFE" CornerRadius="8" Padding="16,14"
                    Visibility="{Binding MostraTasso,
                                 Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Tasso occupazione"
                               FontSize="12" Foreground="#534AB7"
                               Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding TassoOccupazione,
                                          StringFormat='N1'}"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="#3C3489"/>
                            <TextBlock Text="%"
                                   FontSize="16" Foreground="#534AB7"
                                   VerticalAlignment="Bottom"
                                   Margin="3,0,0,3"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Pannello errore -->
            <Border Grid.Row="3"
                Background="#FFEBE8" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16"
                Visibility="{Binding MessaggioErrore,
                             Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{Binding MessaggioErrore}"
                       Foreground="#A32D2D" FontSize="13"/>
            </Border>

            <!-- Grafico -->
            <Border Grid.Row="4"
                Background="#F5F5F5" CornerRadius="8" Padding="16">
                <lvc:CartesianChart Series="{Binding SerieGrafico}"
                                LegendLocation="Top">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Labels="{Binding EtichetteDateGrafico}">
                            <lvc:Axis.Separator>
                                <lvc:Separator IsEnabled="True" StrokeThickness="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis MinValue="0">
                            <lvc:Axis.Separator>
                                <lvc:Separator IsEnabled="True" StrokeThickness="1"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Border>

        </Grid>
    </ScrollViewer>

</UserControl>
