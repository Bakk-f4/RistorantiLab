<UserControl x:Class="UI.Views.UtenteDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16" MaxWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Titolo}"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Username -->
            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,14">
                <TextBlock Text="Username *"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding UserName,
                                UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding UserNameAbilitato}"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="{Binding LabelPassword}"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
            </StackPanel>

            <!-- Email -->
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,14">
                <TextBlock Text="Email *"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Email,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Telefono -->
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Telefono"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Telefono,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Città -->
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,14">
                <TextBlock Text="Città"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Citta,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Descrizione -->
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,14">
                <TextBlock Text="Descrizione"
                           FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Descrizione,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Amministratore -->
            <StackPanel Grid.Row="3" Grid.Column="0"
                        Orientation="Horizontal"
                        Margin="0,0,8,14">
                <CheckBox IsChecked="{Binding IsAdministrator}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>
                <TextBlock Text="Amministratore"
                           FontSize="13"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Pannello errore -->
        <Border Grid.Row="2"
                Background="#FFEBE8" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,16"
                Visibility="{Binding MessaggioErrore,
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioErrore}"
                       Foreground="#A32D2D" FontSize="13"/>
        </Border>

        <!-- Bottoni -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Annulla"
                    Command="{Binding AnnullaCommand}"
                    Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="Salva"
                    Command="{Binding SalvaCommand}"
                    Padding="16,8"
                    Background="#534AB7" Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>

    </Grid>
</UserControl>
