<UserControl x:Class="UI.Views.PrenotazioneListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UI.Views"
             xmlns:helpers="clr-namespace:UI.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>


    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- filtri -->
            <RowDefinition Height="Auto"/>
            <!-- card posti -->
            <RowDefinition Height="Auto"/>
            <!-- errore / successo -->
            <RowDefinition Height="*"/>
            <!-- tabella -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Prenotazioni"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                
                <Button Content="Nuova prenotazione"
                        Command="{Binding NuovaCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Background="#534AB7" Foreground="White"
                        BorderThickness="0"
                        />
                
                <Button Content="Modifica"
                        Command="{Binding ModificaCommand}"
                        Padding="12,6" Margin="0,0,8,0"
                        Visibility="{Binding PuoModificareSelezionata, 
                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                
                <Button Content="Elimina"
                        Command="{Binding EliminaCommand}"
                        Padding="12,6"
                        Visibility="{Binding PuoModificareSelezionata, 
                            Converter={StaticResource BooleanToVisibilityConverter}}"/>
                
            </StackPanel>
        </Grid>

        <!-- Filtri: ristorante + data -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Ristorante"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding ListaRistoranti}"
                          SelectedItem="{Binding RistoranteSelezionato}"
                          DisplayMemberPath="RagioneSociale"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Data"
                           FontSize="12" Foreground="#666"
                           Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding DataFiltro}"/>
            </StackPanel>
        </Grid>

        <!-- Card posti — visibili solo se un ristorante è selezionato -->
        <Grid Grid.Row="2" Margin="0,0,0,16"
              Visibility="{Binding RistoranteSelezionato,
                           Converter={StaticResource NullToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,8,0"
                    Background="#F5F5F5" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Posti totali"
                               FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding PostiTotali}"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#1A1A1A"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="4,0"
                    Background="#FFF3F3" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Occupati"
                               FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding PostiOccupati}"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#A32D2D"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="8,0,0,0"
                    Background="#F0FFF4" CornerRadius="8" Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Disponibili"
                               FontSize="12" Foreground="#666"/>
                    <TextBlock Text="{Binding PostiDisponibili}"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="#2E7D32"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Messaggi errore / successo -->
        <Border Grid.Row="3"
                Background="#FFEBE8" BorderBrush="#E24B4A"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding MessaggioErrore,
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioErrore}"
                       Foreground="#A32D2D" FontSize="13"/>
        </Border>

        <Border Grid.Row="3"
                Background="#E8F5E9" BorderBrush="#4CAF50"
                BorderThickness="1" CornerRadius="4"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding MessaggioSuccesso,
                             Converter={StaticResource NullToVisibilityConverter}}">
            <TextBlock Text="{Binding MessaggioSuccesso}"
                       Foreground="#2E7D32" FontSize="13"/>
        </Border>

        <!-- Tabella prenotazioni -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding ListaPrenotazioni}"
                  SelectedItem="{Binding PrenotazioneSelezionata}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F8F8F8"
                  BorderThickness="1" BorderBrush="#E0E0E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Utente"
                                    Binding="{Binding NomeUtente}"
                                    Width="*"/>
                <DataGridTextColumn Header="Data prenotazione"
                                    Binding="{Binding DataPrenotazione,
                                              StringFormat='dd/MM/yyyy HH:mm'}"
                                    Width="*"/>
                <DataGridTextColumn Header="Persone"
                                    Binding="{Binding NumeroPersone}"
                                    Width="80"/>
                <DataGridTextColumn Header="Richiesta il"
                                    Binding="{Binding DataRichiesta,
                                              StringFormat='dd/MM/yyyy'}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>

</UserControl>
